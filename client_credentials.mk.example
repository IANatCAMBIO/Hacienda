# One-time developer setup for Google Tasks sync — copy this file to
# client_credentials.mk (gitignored) and fill in the credentials of a
# "Desktop app" OAuth client from the Google Cloud console (with the
# Google Tasks API enabled), then rebuild.  The values are baked into
# the binary; users of the build never see them — Sync is just a
# browser sign-in for them.
GOOGLE_CLIENT_ID     = 000000000000-xxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET = GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx
